rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /creditPlans/{planId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.plan in ['free', 'payg', 'pro', 'unlimited']
                    && request.resource.data.credits is number
                    && request.resource.data.credits >= 0;

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['credits', 'creditsUsedThisMonth', 'dailyEnhancesUsed', 'dailyEnhancesResetAt'])
                    && request.resource.data.credits is number
                    && request.resource.data.credits >= 0;
    }

    match /transactions/{transactionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    match /usageLogs/{logId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    match /audioFiles/{fileId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
