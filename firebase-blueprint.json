{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "credits": {
          "type": "number",
          "description": "The user's available credits"
        },
        "role": {
          "type": "string",
          "description": "The user's role (e.g., 'user', 'admin')"
        },
        "tier": {
          "type": "string",
          "description": "The user's subscription tier (e.g., 'free', 'pro', 'unlimited')"
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the user account was created"
        }
      },
      "required": ["uid", "email", "credits", "role", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and credit balances"
    }
  }
}
